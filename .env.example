# TGL (The Guestlist) Configuration
# Variables can be specified with or without the TGL_ prefix
# Examples: Both TGL_PATREON_RSS_URL and PATREON_RSS_URL work
# The TGL_ prefix is recommended for new installations

# Patreon RSS Feed URL
# You can find this in your Patreon account under the podcast settings
# or by checking the podcast in your podcast app
TGL_PATREON_RSS_URL=https://www.patreon.com/rss/your-creator-name?auth=your-auth-token

# Spotify API Credentials
# Create an app at: https://developer.spotify.com/dashboard
TGL_SPOTIFY_CLIENT_ID=your_spotify_client_id
TGL_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
TGL_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Playlist Configuration
TGL_SPOTIFY_PLAYLIST_NAME=TGL

# Optional: Override data directory location
# By default, TGL uses platform-specific directories:
# - macOS: ~/Library/Application Support/TGL
# - Linux: ~/.local/share/TGL
# - Windows: C:\Users\<user>\AppData\Local\TGL
# Uncomment to use a custom location:
# TGL_DATA_DIR=/custom/path/to/data
