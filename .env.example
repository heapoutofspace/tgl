# Patreon RSS Feed URL
# You can find this in your Patreon account under the podcast settings
# or by checking the podcast in your podcast app
PATREON_RSS_URL=https://www.patreon.com/rss/your-creator-name?auth=your-auth-token

# Spotify API Credentials
# Create an app at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Playlist Configuration
SPOTIFY_PLAYLIST_NAME=DJ Patreon Mixes
